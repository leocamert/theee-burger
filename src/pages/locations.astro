---
import Base from '../layouts/Base.astro';
import loc from '../data/locations.json';
const mapSrc = `https://maps.google.com/maps?q=${encodeURIComponent(loc.mapQuery)}&z=15&output=embed`;
---
<Base title="Locations — THEEE BURGER" description="Find THEEE BURGER in San Pedro Square, Downtown San Jose. Walk in and order from your table.">

  <header class="page-hero">
    <div class="container">
      <span class="eyebrow">{loc.eyebrow}</span>
      <h1>{loc.title}</h1>
      <p>{loc.intro}</p>
    </div>
  </header>

  <!-- Storefront -->
  <section class="scene" style="height:64vh; min-height:440px;">
    <img class="scene__bg" src="/images/loc-storefront.jpg" alt="THEEE BURGER storefront at dusk" />
    <div class="scene__shade shade-bottom"></div>
  </section>

  <section class="section">
    <div class="container">
      <div class="split">
        <div class="reveal">
          <h2 class="section-title" style="font-size:clamp(30px,4.5vw,52px);">{loc.name}</h2>
          <ul class="info-list" style="margin-top:26px;">
            <li><span class="k">Address</span><span class="v">{loc.addressLine}</span></li>
            <li><span class="k">Area</span><span class="v">{loc.neighborhood}</span></li>
            <li><span class="k">Phone</span><span class="v"><a href={`tel:${loc.phone.replace(/[^0-9+]/g, '')}`}>{loc.phone}</a></span></li>
            <li><span class="k">Email</span><span class="v"><a href={`mailto:${loc.email}`}>{loc.email}</a></span></li>
          </ul>
          <h3 style="font-size:22px; margin:30px 0 10px;">Hours</h3>
          <ul class="info-list">
            {loc.hours.map((h) => (
              <li><span class="k">{h.days}</span><span class="v">{h.time}</span></li>
            ))}
          </ul>
          <p class="muted" style="margin-top:24px;">{loc.note}</p>
          <div class="btn-row" style="margin-top:26px;">
            <a href="/order" class="btn btn--red">Order to your table</a>
          </div>
        </div>
        <div class="reveal d1">
          <div class="map-frame"><iframe src={mapSrc} loading="lazy" title="Map to THEEE BURGER" referrerpolicy="no-referrer-when-downgrade"></iframe></div>
          <a class="muted" style="display:inline-block; margin-top:14px; font-size:14px; border-bottom:1px solid var(--line);" href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(loc.mapQuery)}`} target="_blank" rel="noopener">Get directions on Google Maps →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Interior + kitchen -->
  <section class="section--tight">
    <div class="container">
      <div class="grid grid--2">
        <div class="split__media reveal"><img src="/images/loc-interior.jpg" alt="Inside the restaurant" loading="lazy" /></div>
        <div class="split__media reveal d1"><img src="/images/loc-kitchen.jpg" alt="Open kitchen and grill" loading="lazy" /></div>
      </div>
    </div>
  </section>

</Base>
