---
import Base from '../layouts/Base.astro';
import ScrollBurger from '../components/ScrollBurger.astro';
import MenuCard from '../components/MenuCard.astro';
import home from '../data/home.json';
import menu from '../data/menu.json';
const featured = menu.burgers.slice(0, 3);
const drinks = menu.drinks;
---
<Base title="THEEE BURGER — Flame-grilled in San Jose" description="Hand-pressed, flame-grilled burgers in San Jose. Burger? Right here.">

  <ScrollBurger />

  <!-- Real fire band -->
  <section class="section scene">
    <img class="scene__bg" src="/images/home-embers.jpg" alt="" aria-hidden="true" />
    <div class="scene__shade shade-full"></div>
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">{home.introEyebrow}</span>
        <h2 class="section-title">{home.introTitle}</h2>
        <p>{home.introText}</p>
      </div>
      <div class="stats">
        {home.stats.map((s, i) => (
          <div class={`reveal d${i + 1}`}>
            <div class="stat__value"><em>{s.value}</em></div>
            <div class="stat__label">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Signature stacks -->
  <section class="section section--tight">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">{home.featuredEyebrow}</span>
        <h2 class="section-title">{home.featuredTitle}</h2>
        <p>{home.featuredText}</p>
      </div>
      <div class="grid grid--3">
        {featured.map((item) => <MenuCard item={item} />)}
      </div>
      <div class="btn-row reveal" style="margin-top:40px;">
        <a href="/menu" class="btn btn--red">See the full menu</a>
      </div>
    </div>
  </section>

  <!-- Drinks -->
  <section class="section scene">
    <img class="scene__bg" src="/images/home-smoke.jpg" alt="" aria-hidden="true" style="opacity:.5;" />
    <div class="scene__shade shade-full"></div>
    <div class="container">
      <div class="section-head reveal" style="text-align:center; margin-left:auto; margin-right:auto;">
        <span class="eyebrow">{home.drinksEyebrow}</span>
        <h2 class="section-title">{home.drinksTitle}</h2>
        <p>{home.drinksText}</p>
      </div>
      <div class="drinks">
        {drinks.map((d, i) => (
          <div class={`drink reveal d${(i % 3) + 1}`}>
            <div class="drink__img"><img src={d.image} alt={d.name} loading="lazy" /></div>
            <div class="drink__name">{d.name}</div>
            <div class="drink__price">${d.price.toFixed(2)}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Combo split -->
  <section class="section">
    <div class="container">
      <div class="split">
        <div class="split__media reveal"><img src="/images/home-combo.jpg" alt="Burger, fries and a drink combo" loading="lazy" /></div>
        <div class="reveal d1">
          <span class="eyebrow">{home.comboEyebrow}</span>
          <h2 class="section-title" style="margin-top:14px;">{home.comboTitle}</h2>
          <p class="muted" style="margin-top:18px; font-size:18px;">{home.comboText}</p>
          <div class="btn-row" style="margin-top:28px;">
            <a href="/menu" class="btn btn--ghost">Build a combo</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sauce drip divider -->
  <div class="drip" aria-hidden="true"><img src="/images/home-sauce-drip.png" alt="" /></div>

  <!-- CTA -->
  <section class="section scene cta">
    <img class="scene__bg" src="/images/home-hero.jpg" alt="" aria-hidden="true" />
    <div class="scene__shade shade-full"></div>
    <div class="container">
      <div class="cta__inner reveal">
        <h2 class="display" style="font-size:clamp(36px,6.5vw,80px);">{home.ctaTitle}</h2>
        <p class="muted" style="margin-top:18px; font-size:19px;">{home.ctaText}</p>
        <div class="btn-row" style="margin-top:30px;">
          <a href="/order" class="btn btn--red">Order to your table</a>
          <a href="/locations" class="btn btn--ghost">Find us</a>
        </div>
      </div>
    </div>
  </section>

</Base>
