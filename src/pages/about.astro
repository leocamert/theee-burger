---
import Base from '../layouts/Base.astro';
import about from '../data/about.json';
---
<Base title="Our story — THEEE BURGER" description="Flame-grilled in San Jose since 2014. The story behind THEEE BURGER.">

  <header class="page-hero">
    <div class="container">
      <span class="eyebrow">{about.eyebrow}</span>
      <h1>{about.title}</h1>
      <p>{about.lead}</p>
    </div>
  </header>

  <!-- Chef / grill scene -->
  <section class="scene" style="height:62vh; min-height:420px;">
    <img class="scene__bg" src={about.imageChef} alt="Chef flame-grilling a burger" />
    <div class="scene__shade shade-bottom"></div>
  </section>

  <section class="section">
    <div class="container">
      <div class="split split--story">
        <div class="split__media reveal"><img src={about.imageIngredients} alt="Fresh burger ingredients" loading="lazy" /></div>
        <div class="reveal d1">
          {about.paragraphs.map((p) => <p style="margin-bottom:20px; font-size:18px;" class="muted">{p}</p>)}
          <div class="story-values">
            {about.values.map((v) => (
              <div class="story-value">
                <h3>{v.title}</h3>
                <p class="muted">{v.text}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- A little more -->
  <section class="section--tight">
    <div class="container" style="max-width:780px;">
      <span class="eyebrow reveal" style="display:block; margin-bottom:14px;">{about.moreEyebrow}</span>
      <h2 class="section-title reveal" style="font-size:clamp(28px,4vw,48px);">{about.moreTitle}</h2>
      {about.moreText.map((p, i) => <p class={`muted reveal d${i + 1}`} style="margin-top:18px; font-size:18px;">{p}</p>)}
    </div>
  </section>

  <!-- Grill scene + stats -->
  <section class="section scene">
    <img class="scene__bg" src={about.imageGrill} alt="" aria-hidden="true" />
    <div class="scene__shade shade-full"></div>
    <div class="container">
      <div class="stats">
        {about.stats.map((s, i) => (
          <div class={`reveal d${i + 1}`}>
            <div class="stat__value"><em>{s.value}</em></div>
            <div class="stat__label">{s.label}</div>
          </div>
        ))}
      </div>
      <p class="display reveal" style="font-size:clamp(30px,5vw,60px); margin-top:60px; text-align:center;">“{about.quote}”</p>
    </div>
  </section>

</Base>
