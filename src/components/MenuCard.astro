---
interface Item { id?: string; name: string; price: number; desc: string; image: string; tag?: string; diet?: string[]; }
const { item, orderable = false } = Astro.props as { item: Item; orderable?: boolean };
---
<article class="card reveal">
  <div class="card__media"><img src={item.image} alt={item.name} loading="lazy" /></div>
  <div class="card__body">
    <div class="card__row">
      <h3 class="card__name">{item.name}</h3>
      <span class="card__price">${item.price.toFixed(2)}</span>
    </div>
    <p class="card__desc">{item.desc}</p>
    {(item.tag || (item.diet && item.diet.length > 0)) && (
      <div class="card__tags">
        {item.tag && <span class="card__tag">{item.tag}</span>}
        {item.diet && item.diet.map((d) => <span class="diet-tag">{d}</span>)}
      </div>
    )}
    {orderable && item.id && (
      <div class="cart-stepper" data-id={item.id} data-name={item.name} data-price={item.price}>
        <button type="button" class="cdec" aria-label={`Remove one ${item.name}`} disabled>&minus;</button>
        <span class="cqty">0</span>
        <button type="button" class="cinc" aria-label={`Add one ${item.name}`}>+</button>
      </div>
    )}
  </div>
</article>
