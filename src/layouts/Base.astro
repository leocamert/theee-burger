---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';

interface Props { title?: string; description?: string; ogImage?: string; keywords?: string; }
const {
  title = 'THEEE BURGER — Flame-Grilled Burgers in San Jose',
  description = 'Hand-pressed, flame-grilled burgers in San Jose. Classic, bacon, spicy, chicken & garden burgers, sides and shakes. Burger? Right here.',
  ogImage = '/og-image.jpg',
  keywords = 'burgers San Jose, best burger San Jose, flame-grilled burger, hand-pressed burger, cheeseburger, San Pedro Square food, THEEE BURGER',
} = Astro.props;
const base = Astro.site ?? 'https://theee-burger.pages.dev';
const ogImageUrl = new URL(ogImage, base).href;
const canonical = new URL(Astro.url.pathname, base).href;
const restaurantSchema = {
  '@context': 'https://schema.org',
  '@type': 'Restaurant',
  name: site.brandName,
  description,
  url: base.toString(),
  image: ogImageUrl,
  telephone: site.phone,
  email: site.email,
  servesCuisine: ['Burgers', 'American'],
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '72 N San Pedro St',
    addressLocality: 'San Jose',
    addressRegion: 'CA',
    postalCode: '95110',
    addressCountry: 'US',
  },
  sameAs: [site.instagram],
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="THEEE BURGER" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <script type="application/ld+json" set:html={JSON.stringify(restaurantSchema)} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      // Scroll reveals
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -7% 0px' });
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      // Parallax on static scene backgrounds (animated smoke is excluded via :not(.anim))
      const bgs = Array.from(document.querySelectorAll('.scene__bg:not(.anim)')) as HTMLElement[];
      // Drinks scale UP as they scroll into view
      const drinks = Array.from(document.querySelectorAll('.drink__img')) as HTMLElement[];

      function frame() {
        const vh = window.innerHeight;
        for (const bg of bgs) {
          const parent = bg.parentElement as HTMLElement;
          const r = parent.getBoundingClientRect();
          const off = ((r.top + r.height / 2) - vh / 2) / vh;
          bg.style.transform = `translateY(${(off * -42).toFixed(1)}px)`;
        }
        for (const el of drinks) {
          const r = el.getBoundingClientRect();
          const c = r.top + r.height / 2;
          let t = (vh - c) / (vh * 0.55);
          t = Math.max(0, Math.min(1, t));
          el.style.transform = `scale(${(0.62 + 0.38 * t).toFixed(3)})`;
        }
      }
      if (!reduce && (bgs.length || drinks.length)) {
        window.addEventListener('scroll', () => requestAnimationFrame(frame), { passive: true });
        window.addEventListener('resize', frame);
        frame();
      }
    </script>
  </body>
</html>
